GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Optional overrides
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_TEMPERATURE=0.2
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Sent as header X-Webhook-Secret (maps to WHATSAPP_WEBHOOK_SECRET in env)
WHATSAPP_WEBHOOK_SECRET=
NGROK_AUTHTOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Optional: override default Telegram API host
# TELEGRAM_API_BASE=https://api.telegram.org
# Set to true locally to enable POST /debug/run
ALLOW_DEBUG=false
